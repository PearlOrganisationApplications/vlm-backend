{
  "info": {
    "name": "Wallet Feature API Testing",
    "description": "Postman Collection for testing the Wallet and Razorpay integration in vlm-backend.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "1. Create Top-Up Order",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{jwt_token}}",
            "type": "text"
          },
          {
            "key": "Content-Type",
            "value": "application/json",
            "type": "text"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"amount\": 500\n}"
        },
        "url": {
          "raw": "{{base_url}}/api/wallet/create-order",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "api",
            "wallet",
            "create-order"
          ]
        },
        "description": "Step 1: Authenticated user requests to top up their wallet by providing an amount in rupees. The response will return a Razorpay orderId."
      },
      "response": []
    },
    {
      "name": "2. Simulate Webhook (payment.captured)",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "X-Razorpay-Signature",
            "value": "{{razorpay_signature}}",
            "type": "text",
            "description": "Generate this signature using HMAC SHA256 of the raw body and your RAZORPAY_WEBHOOK_SECRET."
          },
          {
            "key": "Content-Type",
            "value": "application/json",
            "type": "text"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"entity\": \"event\",\n  \"account_id\": \"acc_ABC123\",\n  \"event\": \"payment.captured\",\n  \"contains\": [\"payment\"],\n  \"payload\": {\n    \"payment\": {\n      \"entity\": {\n        \"id\": \"pay_XYZ987\",\n        \"entity\": \"payment\",\n        \"amount\": 50000,\n        \"currency\": \"INR\",\n        \"status\": \"captured\",\n        \"order_id\": \"order_ABC123\",\n        \"notes\": {\n          \"userId\": \"{{user_object_id}}\"\n        }\n      }\n    }\n  },\n  \"created_at\": 1600000000\n}"
        },
        "url": {
          "raw": "{{base_url}}/api/wallet/webhook",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "api",
            "wallet",
            "webhook"
          ]
        },
        "description": "Step 2: Razorpay sends this webhook event asynchronously when a payment succeeds. It verifies the signature, prevents duplicate credit, and increases the wallet balance."
      },
      "response": []
    },
    {
      "name": "3. Get Wallet Balance",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{jwt_token}}",
            "type": "text"
          }
        ],
        "url": {
          "raw": "{{base_url}}/api/wallet/balance",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "api",
            "wallet",
            "balance"
          ]
        },
        "description": "Step 3: Fetches the current wallet balance of the authenticated user. This reads from the `wallet.totalBalance` field in the Student profile."
      },
      "response": []
    },
    {
      "name": "4. Get Wallet Transactions",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{jwt_token}}",
            "type": "text"
          }
        ],
        "url": {
          "raw": "{{base_url}}/api/wallet/transactions?page=1&limit=10",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "api",
            "wallet",
            "transactions"
          ],
          "query": [
            {
              "key": "page",
              "value": "1"
            },
            {
              "key": "limit",
              "value": "10"
            }
          ]
        },
        "description": "Step 4: Retrieves the paginated history of all wallet top-ups and debits for the authenticated user."
      },
      "response": []
    }
  ],
  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "exec": [
          ""
        ]
      }
    },
    {
      "listen": "test",
      "script": {
        "type": "text/javascript",
        "exec": [
          ""
        ]
      }
    }
  ],
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:5000",
      "type": "string"
    },
    {
      "key": "jwt_token",
      "value": "your_valid_user_jwt_token_here",
      "type": "string"
    },
    {
      "key": "razorpay_signature",
      "value": "generate_hmac_sha256_signature_of_body",
      "type": "string"
    },
    {
      "key": "user_object_id",
      "value": "insert_mongodb_user_object_id_here",
      "type": "string"
    }
  ]
}

{
	"info": {
		"name": "VLM Wallet - Fully Automated",
		"description": "Fully automated wallet testing collection.\n\n**HOW TO USE:**\n1. Set `base_url`, `student_phone`, and `student_password` in Collection Variables.\n2. Run \"1. Student Login\" first — token is auto-saved.\n3. All other requests use the token automatically.\n4. For webhook testing, set `razorpay_webhook_secret` variable.\n\nNo manual token copying needed!",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"variable": [
		{ "key": "base_url", "value": "http://localhost:5000", "type": "string" },
		{ "key": "student_phone", "value": "9999999999", "type": "string" },
		{ "key": "student_password", "value": "123456", "type": "string" },
		{ "key": "admin_email", "value": "admin@vlm.com", "type": "string" },
		{ "key": "admin_password", "value": "admin123", "type": "string" },
		{ "key": "auth_token", "value": "", "type": "string" },
		{ "key": "admin_token", "value": "", "type": "string" },
		{ "key": "user_id", "value": "", "type": "string" },
		{ "key": "razorpay_order_id", "value": "", "type": "string" },
		{ "key": "razorpay_webhook_secret", "value": "your_webhook_secret_here", "type": "string" }
	],
	"item": [
		{
			"name": "🔐 Auth",
			"item": [
				{
					"name": "1. Student Login (auto-saves token)",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"const res = pm.response.json();",
									"if (res.success && res.token) {",
									"    pm.collectionVariables.set('auth_token', res.token);",
									"    console.log('✅ Token saved automatically');",
									"}",
									"if (res.data && res.data.userId) {",
									"    pm.collectionVariables.set('user_id', res.data.userId);",
									"    console.log('✅ userId saved:', res.data.userId);",
									"}",
									"pm.test('Login successful', () => {",
									"    pm.expect(res.success).to.be.true;",
									"    pm.expect(res.token).to.be.a('string');",
									"});"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [{ "key": "Content-Type", "value": "application/json" }],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"phone\": \"{{student_phone}}\",\n    \"password\": \"{{student_password}}\"\n}"
						},
						"url": { "raw": "{{base_url}}/api/students/login", "host": ["{{base_url}}"], "path": ["api", "students", "login"] }
					}
				},
				{
					"name": "2. Admin Login (auto-saves token)",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"const res = pm.response.json();",
									"if (res.token) {",
									"    pm.collectionVariables.set('admin_token', res.token);",
									"    console.log('✅ Admin token saved');",
									"}",
									"pm.test('Admin login successful', () => {",
									"    pm.expect(res.token).to.be.a('string');",
									"});"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [{ "key": "Content-Type", "value": "application/json" }],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"email\": \"{{admin_email}}\",\n    \"password\": \"{{admin_password}}\"\n}"
						},
						"url": { "raw": "{{base_url}}/api/admins/login", "host": ["{{base_url}}"], "path": ["api", "admins", "login"] }
					}
				}
			]
		},
		{
			"name": "💰 Wallet - Top Up Flow",
			"item": [
				{
					"name": "3. Create Wallet Top-Up Order",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"const res = pm.response.json();",
									"if (res.success && res.data && res.data.orderId) {",
									"    pm.collectionVariables.set('razorpay_order_id', res.data.orderId);",
									"    console.log('✅ Razorpay Order ID saved:', res.data.orderId);",
									"}",
									"pm.test('Order created successfully', () => {",
									"    pm.expect(res.success).to.be.true;",
									"    pm.expect(res.data.orderId).to.be.a('string');",
									"    pm.expect(res.data.currency).to.eql('INR');",
									"});"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{ "key": "Content-Type", "value": "application/json" },
							{ "key": "Authorization", "value": "Bearer {{auth_token}}" }
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"amount\": 500\n}"
						},
						"url": { "raw": "{{base_url}}/api/wallet/create-order", "host": ["{{base_url}}"], "path": ["api", "wallet", "create-order"] }
					}
				},
				{
					"name": "4. Simulate Razorpay Webhook (payment.captured)",
					"event": [
						{
							"listen": "prerequest",
							"script": {
								"exec": [
									"// Build the webhook payload",
									"const userId = pm.collectionVariables.get('user_id');",
									"const orderId = pm.collectionVariables.get('razorpay_order_id');",
									"const secret = pm.collectionVariables.get('razorpay_webhook_secret');",
									"const paymentId = 'pay_test_' + Date.now();",
									"",
									"const payload = {",
									"    event: 'payment.captured',",
									"    payload: {",
									"        payment: {",
									"            entity: {",
									"                id: paymentId,",
									"                amount: 50000,",
									"                currency: 'INR',",
									"                order_id: orderId,",
									"                method: 'upi',",
									"                status: 'captured',",
									"                notes: { userId: userId }",
									"            }",
									"        }",
									"    }",
									"};",
									"",
									"const rawBody = JSON.stringify(payload);",
									"",
									"// Generate HMAC-SHA256 signature",
									"const signature = CryptoJS.HmacSHA256(rawBody, secret).toString(CryptoJS.enc.Hex);",
									"",
									"pm.collectionVariables.set('_webhook_body', rawBody);",
									"pm.collectionVariables.set('_webhook_signature', signature);",
									"",
									"console.log('✅ Webhook signature generated');",
									"console.log('PaymentId:', paymentId);",
									"console.log('UserId:', userId);"
								],
								"type": "text/javascript"
							}
						},
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test('Webhook processed successfully', () => {",
									"    pm.expect(pm.response.code).to.eql(200);",
									"    const res = pm.response.json();",
									"    pm.expect(res.success).to.be.true;",
									"});"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{ "key": "Content-Type", "value": "application/json" },
							{ "key": "x-razorpay-signature", "value": "{{_webhook_signature}}" }
						],
						"body": {
							"mode": "raw",
							"raw": "{{_webhook_body}}"
						},
						"url": { "raw": "{{base_url}}/api/wallet/webhook", "host": ["{{base_url}}"], "path": ["api", "wallet", "webhook"] }
					}
				}
			]
		},

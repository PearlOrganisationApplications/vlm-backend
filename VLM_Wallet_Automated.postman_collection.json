									"const initial = parseFloat(pm.collectionVariables.get('_initial_balance') || 0);",
									"pm.test('Balance increased by ₹500', () => {",
									"    pm.expect(res.data.balance).to.eql(initial + 500);",
									"});",
									"console.log('Before: ₹' + initial + ' → After: ₹' + res.data.balance);"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "GET",
						"header": [{ "key": "Authorization", "value": "Bearer {{auth_token}}" }],
						"url": { "raw": "{{base_url}}/api/wallet/balance", "host": ["{{base_url}}"], "path": ["api", "wallet", "balance"] }

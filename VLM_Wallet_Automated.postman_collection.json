						],
						"body": { "mode": "raw", "raw": "{\n    \"amount\": 500\n}" },
						"url": { "raw": "{{base_url}}/api/wallet/create-order", "host": ["{{base_url}}"], "path": ["api", "wallet", "create-order"] }
					}
				},
				{
					"name": "E2E-4: Simulate Webhook",
					"event": [
						{
							"listen": "prerequest",
							"script": {
								"exec": [
									"const userId = pm.collectionVariables.get('user_id');",
									"const orderId = pm.collectionVariables.get('razorpay_order_id');",
									"const secret = pm.collectionVariables.get('razorpay_webhook_secret');",
									"const payload = JSON.stringify({",
									"    event: 'payment.captured',",
									"    payload: { payment: { entity: {",
									"        id: 'pay_e2e_' + Date.now(),",
									"        amount: 50000, currency: 'INR',",
									"        order_id: orderId, status: 'captured',",
									"        notes: { userId: userId }",
									"    }}}",
									"});",
									"pm.collectionVariables.set('_webhook_body', payload);",
									"pm.collectionVariables.set('_webhook_signature',",
									"    CryptoJS.HmacSHA256(payload, secret).toString(CryptoJS.enc.Hex));"
								],
								"type": "text/javascript"
							}
						},
						{
							"listen": "test",
							"script": {

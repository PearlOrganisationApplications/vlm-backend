									"if (res.data && res.data.userId) pm.collectionVariables.set('user_id', res.data.userId);",
									"pm.test('Login OK', () => pm.expect(res.success).to.be.true);"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [{ "key": "Content-Type", "value": "application/json" }],
						"body": { "mode": "raw", "raw": "{\n    \"phone\": \"{{student_phone}}\",\n    \"password\": \"{{student_password}}\"\n}" },
						"url": { "raw": "{{base_url}}/api/students/login", "host": ["{{base_url}}"], "path": ["api", "students", "login"] }
					}
				},
